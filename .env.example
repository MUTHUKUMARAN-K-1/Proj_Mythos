# ============================
# Mythos — Environment Config
# AI-Native Agentic Lending on Solana
# ============================

# --- Solana Network ---
SOLANA_NETWORK=devnet
SOLANA_DEMO_MODE=true

# --- Helius RPC (get free key at helius.dev) ---
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WEBHOOK_SECRET=mythos-secret

# --- USDC (Devnet) ---
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# --- Agent Wallets (generated with `solana-keygen new`) ---
# For hackathon demo, leave as placeholders
LENNY_WALLET_ADDRESS=LennyBorrowerAgentXXXXXXXXXXXXXXXXXXXXXXXX
LUNA_WALLET_ADDRESS=LunaLenderAgentXXXXXXXXXXXXXXXXXXXXXXXXX
TREASURY_WALLET=MythosProtocolTreasury111111111111111111111

# --- Mythos Program ID ---
MYTHOS_PROGRAM_ID=FGG8363rUtdVernzHtXr4AD9PS9m4BezgAN8MJKcybpM

# --- AI / LLM ---
# Groq is free and fast — get key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Optional: OpenAI fallback
OPENAI_API_KEY=sk-optional-fallback

# --- Backend ---
PORT=8000
HOST=0.0.0.0

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:8000
VITE_SOLANA_NETWORK=devnet
VITE_HELIUS_API_KEY=your_helius_api_key_here
VITE_MYTHOS_PROGRAM_ID=FGG8363rUtdVernzHtXr4AD9PS9m4BezgAN8MJKcybpM
VITE_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
