# ============================================================================
# Mythos — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values.
#
# DEPLOYMENT:
# - Frontend (Vercel): set VITE_* in Vercel Dashboard → Settings → Env Vars
# - Backend (Railway): set all other vars in Railway Dashboard → Variables
# ============================================================================

# ============================================================================
# FRONTEND — Vercel build-time variables
# ============================================================================

# Backend API URL (your Railway backend URL)
VITE_API_URL=https://your-backend.up.railway.app

# WebSocket URL (wss:// of the same backend)
VITE_WS_URL=wss://your-backend.up.railway.app/ws

# Solana
VITE_SOLANA_NETWORK=devnet
VITE_HELIUS_API_KEY=your_helius_api_key_here
VITE_MYTHOS_PROGRAM_ID=FGG8363rUtdVernzHtXr4AD9PS9m4BezgAN8MJKcybpM
VITE_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ============================================================================
# BACKEND — Railway runtime variables
# ============================================================================

# Server
PORT=8000
HOST=0.0.0.0

# Solana Configuration
SOLANA_NETWORK=devnet
MYTHOS_PROGRAM_ID=FGG8363rUtdVernzHtXr4AD9PS9m4BezgAN8MJKcybpM
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
SOLANA_DEMO_MODE=true

# Helius RPC (https://dashboard.helius.dev)
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=your_helius_api_key_here

# Groq AI (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Jupiter Price API (no key needed for public endpoint)
JUPITER_PRICE_URL=https://price.jup.ag/v6/price

# ============================================================================
# SECURITY CHECKLIST
# ============================================================================
# - Never commit .env to git (already in .gitignore)
# - Rotate GROQ_API_KEY and HELIUS_API_KEY if accidentally exposed
# - Use Railway secrets for production key storage
# ============================================================================
